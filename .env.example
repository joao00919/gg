# =========================================================
# ZYNEX SYSTEMS 4.3.18 - CONFIGURACAO LOCAL
# Copie este arquivo para .env e preencha somente seus dados.
# Nunca envie o arquivo .env para GitHub, Discord ou hospedagem.
# =========================================================

APP_ENV=local
LOG_LEVEL=INFO
DEBUG=false

# Discord
# Você pode usar DISCORD_TOKEN ou BOT_TOKEN. Se ambos existirem, DISCORD_TOKEN tem prioridade.
BOT_TOKEN=
DISCORD_TOKEN=
# Opcional: quando vazio, o ID é identificado automaticamente pelo token.
DISCORD_CLIENT_ID=
# Servidor usado para registrar comandos rapidamente durante testes.
DISCORD_TEST_GUILD_ID=
# Limita comandos e componentes ao servidor informado. Vazio = desativado.
MAIN_GUILD_ID=

# Permissoes administrativas
# Informe seu ID de usuario do Discord. Multiplos IDs: separados por virgula.
BOT_OWNER_IDS=
# Administradores adicionais do bot (opcional).
BOT_ADMIN_IDS=
# true = administradores do servidor tambem podem usar comandos administrativos.
ALLOW_GUILD_ADMIN=true

# Persistencia
# local = JSON local, sem MongoDB
# mongo = MongoDB obrigatorio
# auto  = MongoDB se MONGO_URL existir; caso contrario, local
STORAGE_DRIVER=local
LOCAL_DATABASE_PATH=data/local_database.json
MONGO_URL=
MONGO_DATABASE=zynex_sales
MONGO_TIMEOUT_MS=10000

# Recursos do projeto
# basic evita conexoes com sistemas cloud legados durante o teste local.
BOT_PLAN=basic
SYNC_APPLICATION_EMOJIS=true
AUTO_UPDATE_APPLICATION_PROFILE=false
MONITOR_APPLICATION_PROFILE=false
APPLICATION_DESCRIPTION=ZYNEX Systems

# API usada pelo ZYNEX Manager. Pode ficar ligada no teste local.
PRIVATE_API_ENABLED=true
PRIVATE_API_PORT=8080
SALES_BOT_API_KEY=
MANAGER_APPLICATION_ID=

# ZYNEX Manager - opcionais durante o teste isolado
MANAGER_API_URL=
MANAGER_INTERNAL_API_KEY=
MANAGER_SALES_API_KEY=

# Logs externos - opcional
INTERACTION_LOG_WEBHOOK_URL=

# WhatsApp - opcional e desativado enquanto estiver vazio
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# Identidade visual opcional
BRAND_NAME=ZYNEX Systems
SUPPORT_URL=

# Integrações de IA e extensões - opcionais
AI_PRIMARY_URL=
AI_PRIMARY_TOKEN=
GROQ_API_KEY=
GROQ_API_KEYS=
ZYNEXGEN_API_URL=
ZYNEXGEN_BOT_SECRET=

# Carteira Integrada — PurinCash (credencial global do operador)
# Crie a chave no painel PurinCash e use o ambiente correto: ps_test_ ou ps_live_.
PURINCASH_API_KEY=
PURINCASH_API_URL=https://api.purincash.com/v1
# URL HTTPS pública que aponta para PRIVATE_API_PORT e termina em /webhooks/purincash
PURINCASH_CALLBACK_URL=
PURINCASH_WEBHOOK_SECRET=
# Chave PIX usada nos saques quando nenhuma for informada no painel
PURINCASH_PIX_KEY=
# Taxa operacional exibida no painel; ajuste conforme o plano contratado.
PURINCASH_OPERATION_FEE_PERCENT=0.60
PURINCASH_OPERATION_FEE_FIXED=0.25

# Compatibilidade com instalações antigas (opcional; prefira PURINCASH_API_KEY)
ZYNEX_WALLET_API_URL=
ZYNEX_WALLET_API_KEY=
ENABLE_CLOUD_WEBSOCKET=false
ENABLE_PAYMENT_WEBSOCKET=false
SEND_RESTART_LOG=true

# Operação ZYNEX
ZYNEX_STRICT_COMMAND_SET=true
ZYNEX_AUTOMATIC_BACKUP=true
ZYNEX_BACKUP_DIR=backups
ZYNEX_BACKUP_ROTATION=10
ZYNEX_MIGRATION_BACKUP=true
ZYNEX_MONTHLY_REPORT=true
OWNER_ID=

# API pública de transcripts
TRANSCRIPT_API_URL=https://SEU-SUBDOMINIO-TRANSCRIPTS.camposcloud.com
TRANSCRIPT_API_KEY=USE_A_MESMA_CHAVE_CONFIGURADA_NA_API
RESTART_NOTICE_CHANNEL_ID=
TRANSCRIPT_ENABLED=true

TRANSCRIPT_TTL_HOURS=72
DISABLE_APPLICATION_EMOJI_SYNC=false

# Confere se os IDs dos emojis pertencem ao bot atual
VERIFY_APPLICATION_EMOJIS_ON_STARTUP=true
